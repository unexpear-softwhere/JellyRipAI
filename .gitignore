dist/ffprobe.exe
dist/JellyRip.exe
dist/JellyRipInstaller.exe
dist/JellyRipAI.exe
dist/JellyRipAIInstaller.exe

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
.profiles/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Config
config.json
*.log
rip_log.txt

# Local snapshot helpers
.git_head_now.txt
.git_status_now.txt

# Session debris (pytest log, diff scratch, codex auto-backups)
..txt
origin_main_controller.tmp
.codex_backup/

# Claude IDE artifacts — local tool permission allowlists, session
# transcripts, worktrees, plus the per-project working-memory file.
# CLAUDE.md was committed before but its content is duplicated in
# README.md / docs/repository-layout.md; keeping it local-only
# avoids leaking Claude-directive content to the remote.
.claude/
!.claude/.gitkeep
CLAUDE.md

# Local-only experiments + test artifacts.
experiments/
tests/_test_qss_empty_placeholder_tmp/

# Visual-asset reference snapshot of the retired tkinter UI.  Kept
# local for as long as it's useful but does not belong in the public
# tree alongside the live gui_qt/ implementation.
ui_visual_assets_copy/

# Claude productivity dashboard (reads CLAUDE.md, renders memory
# tabs).  Defensive — file doesn't exist on AI side today, but if
# Claude ever drops it here it must not get tracked alongside
# CLAUDE.md (which is already gitignored above).
dashboard.html

# Local scratch / .tmp artifacts that aren't part of project source.
*.tmp
